{
	"method": "sendMessage",
	"errors": [
		{
			"tag": "ChatIdEmpty",
			"errorCode": 400,
			"description": "Bad Request: chat_id is empty",
			"when": "chat_id parameter is missing"
		},
		{
			"tag": "ChatNotFound",
			"errorCode": 400,
			"description": "Bad Request: chat not found",
			"when": "chat_id does not refer to a chat the bot can access"
		},
		{
			"tag": "MessageTextEmpty",
			"errorCode": 400,
			"description": "Bad Request: message text is empty",
			"when": "text is missing or empty"
		},
		{
			"tag": "MessageTooLong",
			"errorCode": 400,
			"description": "Bad Request: message is too long",
			"when": "text exceeds 4096 characters"
		}
	]
}
