{
	"method": "getUserProfilePhotos",
	"errors": [
		{
			"tag": "InvalidUserId",
			"errorCode": 400,
			"description": "Bad Request: invalid user_id specified",
			"when": "user_id is missing or zero"
		},
		{
			"tag": "UserNotFound",
			"errorCode": 400,
			"description": "Bad Request: user not found",
			"when": "user_id does not refer to an existing user"
		}
	]
}
