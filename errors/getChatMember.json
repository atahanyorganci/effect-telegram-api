{
	"method": "getChatMember",
	"errors": [
		{
			"tag": "ChatIdEmpty",
			"errorCode": 400,
			"description": "Bad Request: chat_id is empty",
			"when": "chat_id parameter is missing"
		},
		{
			"tag": "ChatNotFound",
			"errorCode": 400,
			"description": "Bad Request: chat not found",
			"when": "chat_id does not refer to a chat the bot can access"
		},
		{
			"tag": "InvalidUserId",
			"errorCode": 400,
			"description": "Bad Request: invalid user_id specified",
			"when": "user_id is missing or zero"
		},
		{
			"tag": "MemberNotFound",
			"errorCode": 400,
			"description": "Bad Request: member not found",
			"when": "user_id is not a member of the chat"
		},
		{
			"tag": "ParticipantIdInvalid",
			"errorCode": 400,
			"description": "Bad Request: PARTICIPANT_ID_INVALID",
			"when": "user_id does not refer to a chat participant"
		}
	]
}
